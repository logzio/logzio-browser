{
  "name": "@logzio/browser",
  "version": "1.3.0",
  "description": "Library for collecting Real User Monitoring (RUM) in JavaScript and forwarding to Logz.io.",
  "keywords": [
    "rum",
    "real user monitoring",
    "logzio",
    "opentelemetry",
    "browser",
    "traces",
    "logs",
    "web vitals",
    "performance monitoring"
  ],
  "homepage": "https://github.com/logzio/logzio-browser#readme",
  "bugs": {
    "url": "https://github.com/logzio/logzio-browser/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logzio/logzio-browser.git"
  },
  "license": "Apache-2.0",
  "author": "Logz.io",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit && npm run test:integration && npm run test:browser",
    "test:unit": "jest --config tests/unit/jest.config.cjs tests/unit/",
    "test:integration": "NODE_OPTIONS=--unhandled-rejections=warn jest --config tests/integration/jest.config.cjs",
    "test:browser": "playwright test --config tests/browser/playwright.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-document-load": "^0.59.0",
    "@opentelemetry/instrumentation-fetch": "^0.214.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.58.0",
    "@opentelemetry/instrumentation-web-exception": "^0.7.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "uuid": "^13.0.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
